      "parameters": {
        "jsCode": "return items.map(item => {\n  let text = \"\";\n\n  if (typeof item.json.body === \"string\") {\n    text = item.json.body;\n  } else if (item.json.body?.message) {\n    text = item.json.body.message;\n  } else if (item.json.text) {\n    text = item.json.text;\n  }\n\n  text = String(text)\n    .replace(/<[^>]*>?/gm, \"\") // remove HTML\n    .slice(0, 1000);\n\n  return {\n    json: {\n      ...item.json,   // ✅ KEEP ORIGINAL DATA\n      cleaned_text: text // ✅ ADD NEW FIELD\n    }\n  };\n});"
